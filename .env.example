# AI Path - 환경변수 템플릿
# 이 파일을 .env 로 복사 후 값을 채워주세요: cp .env.example .env

# ── LLM Provider ─────────────────────────────────────
# 'ollama' : 로컬 GPU 서버 (무료, 프라이버시 보장)
# 'upstage': Upstage Solar API (클라우드, 빠른 응답)
LLM_PROVIDER=ollama

# ── Ollama 설정 (LLM_PROVIDER=ollama 일 때) ───────────
# CORS 해결을 위해 Ollama 실행 시 아래 환경변수 필요:
#   Windows : set OLLAMA_ORIGINS=* && ollama serve
#   macOS/Linux: OLLAMA_ORIGINS=* ollama serve
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── Upstage 설정 (LLM_PROVIDER=upstage 일 때) ────────
UPSTAGE_API_KEY=your_upstage_api_key_here
UPSTAGE_MODEL=solar-pro

# ── 앱 설정 ─────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
